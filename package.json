{
  "name": "party-level-architect",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "vite build && wrangler dev",
    "dev:lan": "vite build && wrangler dev --ip 0.0.0.0",
    "rehearsal": "node scripts/rehearsal.mjs",
    "check": "tsc --noEmit && tsc -p worker --noEmit",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy": "npm run check && vite build && wrangler deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "lil-gui": "^0.19.2",
    "phaser": "^3.85.2",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260611.1",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "wrangler": "^4.100.0"
  }
}
